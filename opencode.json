{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "defi-expert": {}
  },
  "mcp": {
    "ymax-yield-agent": {
      "type": "local",
      "command": ["npx", "tsx", "mcp-server/src/server.ts"],
      "enabled": true,
      "env": {
        "SPONSOR_MNEMONIC": "{env:SPONSOR_MNEMONIC}",
        "SPONSOR_PRIVATE_KEY": "{env:SPONSOR_PRIVATE_KEY}",
        "RPC_URL": "{env:RPC_URL}"
      }
    }
  }
}