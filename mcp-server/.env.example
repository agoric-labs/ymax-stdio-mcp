# Sponsor wallet (set exactly one)
SPONSOR_MNEMONIC="twenty four word mnemonic phrase goes here"
# or
SPONSOR_PRIVATE_KEY=0xabcdef123456...

# RPC endpoint (defaults to mainnet)
# RPC_URL=https://main.rpc.agoric.net:443

# YDS transaction registration (defaults to ymax0 mainnet)
# YDS_URL=https://main0.ymax.app
# CHAIN_ID=agoric-3
# YMAX_INSTANCE=ymax0

# BLD amount to fund each delegate (default 20000000 = 20 BLD)
# SPONSOR_AMOUNT=20000000

# YMax UI used for proposal links. This preview includes Agoric/ymax-web#840.
# YMAX_UI_URL=https://staging-agentic-ui.ymax0-ui.pages.dev
